{
  "name": "codex-slot",
  "version": "0.1.16",
  "description": "本地 Codex 多账号切换与状态管理工具",
  "type": "commonjs",
  "main": "dist/cli.js",
  "bin": {
    "codex-slot": "dist/cli.js",
    "cslot": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json && chmod +x dist/cli.js dist/serve.js",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/cli.ts",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.js"
  },
  "keywords": [
    "codex",
    "chatgpt",
    "switcher",
    "cli"
  ],
  "author": "bk",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openxiaobu/codex-slot.git"
  },
  "homepage": "https://github.com/openxiaobu/codex-slot#readme",
  "bugs": {
    "url": "https://github.com/openxiaobu/codex-slot/issues"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "fastify": "^5.8.2",
    "undici": "^7.22.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
